# 复制为 .env 并填写实际值（用户名和密码按你本机 MySQL 填写）
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
# 格式：mysql+pymysql://用户名:密码@主机:端口/数据库名（密码若含特殊字符需 URL 编码）
DATABASE_URL=mysql+pymysql://root:YOUR_PASSWORD@localhost:3306/sydixon_order

# OpenClaw 对话接入：API Key（与 X-API-Key 或 Authorization: Bearer 一致）。不配置则 /api/openclaw 接口返回 503。
# OPENCLAW_API_KEY=your-openclaw-api-key
