# 复制为 .env 并填写实际值（用户名和密码按你本机 MySQL 填写）
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
# 格式：mysql+pymysql://用户名:密码@主机:端口/数据库名?charset=utf8mb4（密码若含特殊字符需 URL 编码）
# charset=utf8mb4 避免中文客户名等写入乱码；库表亦须 utf8mb4
DATABASE_URL=mysql+pymysql://root:YOUR_PASSWORD@localhost:3306/sydixon_order?charset=utf8mb4

# 送货单「标记已发」自动出库时使用的仓储区编码（如 B18）；不配置则无法自动出库
# INVENTORY_DEFAULT_STORAGE_AREA=B18

# OpenClaw：任选其一或并存——(1) 全局 Key，不限 RBAC；(2) 用户令牌：flask openclaw-token-create <用户名> 生成，走角色菜单+细项能力（须具备 openclaw.* 能力）。
# OPENCLAW_API_KEY=your-openclaw-api-key
# 每分钟每 IP 请求上限（0 表示不限制）。默认 120。
# OPENCLAW_RATE_LIMIT_PER_MINUTE=120
